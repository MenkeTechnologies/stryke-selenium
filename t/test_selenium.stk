## t/test_selenium.stk — assertion tests for the stryke `Selenium` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Exercises the FFI surface without needing a WebDriver server:
## `supported_browsers`, `locator_strategies`, and `sessions` (empty when
## no browsers are open) are all pure dispatch into static state inside
## the cdylib — no chromedriver / geckodriver / safaridriver required, so
## they run unattended in CI.
##
## Live browser ops (open / goto / find / click / screenshot) need a
## running WebDriver server + a real browser, so they're not asserted
## here — they're exercised by `examples/selenium_*.stk` against a
## locally-launched chromedriver.

use Selenium

# ── Selenium::supported_browsers FFI roundtrip ──────────────────────
# Proves the FFI call path end-to-end: stryke → selenium__supported_browsers
# → JSON → stryke. No WebDriver server contacted.
val @browsers = Selenium::supported_browsers()
assert_ge scalar(@browsers), 4, "supported_browsers returns >= 4 names"

val %seen = map { $_ => 1 } @browsers
assert_ok $seen{chrome},  "browsers contain 'chrome'"
assert_ok $seen{firefox}, "browsers contain 'firefox'"
assert_ok $seen{safari},  "browsers contain 'safari'"
assert_ok $seen{edge},    "browsers contain 'edge'"

# ── Selenium::locator_strategies FFI roundtrip ──────────────────────
val @strats = Selenium::locator_strategies()
assert_ge scalar(@strats), 8, "locator_strategies returns >= 8 names"

val %sseen = map { $_ => 1 } @strats
assert_ok $sseen{css},               "strategies contain 'css'"
assert_ok $sseen{id},                "strategies contain 'id'"
assert_ok $sseen{xpath},             "strategies contain 'xpath'"
assert_ok $sseen{name},              "strategies contain 'name'"
assert_ok $sseen{tag},               "strategies contain 'tag'"
assert_ok $sseen{class},             "strategies contain 'class'"
assert_ok $sseen{link_text},         "strategies contain 'link_text'"
assert_ok $sseen{partial_link_text}, "strategies contain 'partial_link_text'"

# ── Selenium::sessions is empty when no browser open ────────────────
# The cdylib was just dlopened by this test; no `Selenium::open` has
# run, so the registry must be empty.
val @sessions = Selenium::sessions()
assert_eq scalar(@sessions), 0, "no sessions open before Selenium::open"

# active() returns undef when no session is active.
val $current = Selenium::active()
assert_ok !defined($current), "active() is undef when no session is open"

# ── quit_all is a no-op safe call when no sessions are open ─────────
val $closed = Selenium::quit_all()
assert_eq $closed, 0, "quit_all closes 0 sessions when none are open"

# ── pure helpers (no browser — always run) ───────────────────────────
val $css = Selenium::parse_locator("css=.btn.primary")
assert_eq $css->{strategy}, "css",         "parse_locator: css strategy"
assert_eq $css->{value},    ".btn.primary", "parse_locator: css value"
assert_eq Selenium::parse_locator("class_name=active")->{strategy}, "class", "parse_locator: alias canonicalized"
# embedded = in an xpath must survive
val $xp = Selenium::parse_locator("xpath=//input[\@type='text']")
assert_eq $xp->{value}, "//input[\@type='text']", "parse_locator: keeps embedded ="

# build_locator: inverse of parse_locator, strategy canonicalized.
assert_eq Selenium::build_locator("css", ".btn.primary")->{locator}, "css=.btn.primary", "build_locator: css"
assert_eq Selenium::build_locator("class_name", "active")->{locator}, "class=active", "build_locator: alias canonicalized"
assert_eq Selenium::build_locator("xpath", "//input[\@type='text']")->{locator}, "xpath=//input[\@type='text']", "build_locator: xpath with = round-trips"
assert_dies fn { Selenium::build_locator("bogus", "x") }, "build_locator: rejects unknown strategy"

val $vs = Selenium::valid_locator_strategy("TAG_NAME")
assert_ok $vs->{valid},                "valid_locator_strategy: alias is valid"
assert_eq $vs->{canonical}, "tag",     "valid_locator_strategy: canonical form"
assert_eq Selenium::valid_locator_strategy("nope")->{valid}, 0, "valid_locator_strategy: rejects unknown"

# locator_to_w3c: the actual WebDriver { using, value } protocol pair.
val $w = Selenium::locator_to_w3c("css", ".btn")
assert_eq $w->{using}, "css selector", "locator_to_w3c: css → css selector"
assert_eq $w->{value}, ".btn",         "locator_to_w3c: value verbatim"
assert_eq Selenium::locator_to_w3c("xpath=//a")->{using}, "xpath", "locator_to_w3c: single-string locator"
assert_eq Selenium::locator_to_w3c("tag_name=div")->{using}, "tag name", "locator_to_w3c: tag name"
# id/name/class collapse to a css selector.
assert_eq Selenium::locator_to_w3c("id", "main")->{value}, "[id=\"main\"]", "locator_to_w3c: id → [id=...]"
assert_eq Selenium::locator_to_w3c("name", "q")->{value}, "[name=\"q\"]", "locator_to_w3c: name → [name=...]"
assert_eq Selenium::locator_to_w3c("class", "active")->{value}, "[class~=\"active\"]", "locator_to_w3c: class → [class~=...]"
assert_dies fn { Selenium::locator_to_w3c("bogus=x") }, "locator_to_w3c: rejects unknown strategy"

# w3c_to_locator: inverse of locator_to_w3c for the five protocol strategies.
assert_eq Selenium::w3c_to_locator("css selector", ".btn")->{strategy}, "css", "w3c_to_locator: css selector → css"
assert_eq Selenium::w3c_to_locator("css selector", ".btn")->{locator}, "css=.btn", "w3c_to_locator: rebuilds the locator string"
assert_eq Selenium::w3c_to_locator("tag name", "div")->{strategy}, "tag", "w3c_to_locator: tag name → tag"
assert_eq Selenium::w3c_to_locator("partial link text", "Ho")->{strategy}, "partial_link_text", "w3c_to_locator: partial link text"
assert_dies fn { Selenium::w3c_to_locator("id", "main") }, "w3c_to_locator: id is not a W3C using strategy"

# key_code: WebDriver special-key Private-Use-Area code points.
assert_eq Selenium::key_code("Enter")->{code_point}, "U+E007", "key_code: Enter is U+E007"
assert_eq Selenium::key_code("Return")->{codepoint}, 57350,    "key_code: Return (E006) differs from Enter"
assert_eq Selenium::key_code("Tab")->{code_point},   "U+E004", "key_code: Tab"
assert_eq Selenium::key_code("esc")->{code_point},   "U+E00C", "key_code: esc alias → Escape"
assert_eq Selenium::key_code("arrow_up")->{code_point}, "U+E013", "key_code: ArrowUp, normalized name"
assert_eq Selenium::key_code("F12")->{code_point},   "U+E03C", "key_code: F12"
assert_dies fn { Selenium::key_code("nope") }, "key_code: rejects an unknown key"

# key_name: inverse — WebDriver PUA code point → canonical key name.
assert_eq Selenium::key_name(codepoint => 57351)->{key}, "enter",  "key_name: U+E007 is enter"
assert_eq Selenium::key_name(codepoint => 57350)->{key}, "return", "key_name: U+E006 is return (distinct from enter)"
assert_eq Selenium::key_name(codepoint => 57356)->{key}, "escape", "key_name: alias collapses to escape"
assert_eq Selenium::key_name(codepoint => 57393)->{key}, "f1",     "key_name: U+E031 is f1"
assert_eq Selenium::key_name(char => Selenium::key_code("ArrowUp")->{char})->{key}, "up", "key_name: round-trips key_code via char"
assert_dies fn { Selenium::key_name(codepoint => 57376) }, "key_name: rejects an unassigned code point"

val $ck = Selenium::parse_cookie("session=abc123; Domain=.example.com; Path=/; Secure; HttpOnly")
assert_eq $ck->{name},   "session",       "parse_cookie: name"
assert_eq $ck->{value},  "abc123",        "parse_cookie: value"
assert_eq $ck->{domain}, ".example.com",  "parse_cookie: domain"
assert_eq $ck->{secure}, 1,               "parse_cookie: secure flag"
assert_eq $ck->{http_only}, 1,            "parse_cookie: http_only flag"

# build_cookie: inverse of parse_cookie (truthy flags become bare attributes).
assert_eq Selenium::build_cookie(name => "session", value => "abc123", domain => ".example.com", path => "/", same_site => "Lax", secure => 1, http_only => 1), "session=abc123; Domain=.example.com; Path=/; SameSite=Lax; Secure; HttpOnly", "build_cookie: full Set-Cookie string"
assert_eq Selenium::build_cookie(name => "k", value => "v"), "k=v", "build_cookie: minimal cookie, no flags"
assert_eq Selenium::parse_cookie(Selenium::build_cookie(name => "s", value => "x", secure => 1))->{secure}, 1, "build_cookie → parse_cookie round-trips the Secure flag"

# cookie_domain_matches: RFC 6265 §5.1.3 domain matching.
assert_eq Selenium::cookie_domain_matches("example.com", "example.com")->{matches}, 1, "cookie_domain_matches: identical domains match"
assert_eq Selenium::cookie_domain_matches("example.com", "www.example.com")->{matches}, 1, "cookie_domain_matches: subdomain with a dot boundary matches"
assert_eq Selenium::cookie_domain_matches(".example.com", "www.example.com")->{matches}, 1, "cookie_domain_matches: a leading dot is ignored"
assert_eq Selenium::cookie_domain_matches("example.com", "notexample.com")->{matches}, 0, "cookie_domain_matches: suffix without a dot boundary does not match"
assert_eq Selenium::cookie_domain_matches("0.0.1", "192.168.0.1")->{matches}, 0, "cookie_domain_matches: an IP host never matches via the suffix rule"
assert_dies fn { Selenium::cookie_domain_matches("x.com") }, "cookie_domain_matches: needs a host"

# cookie_path_matches: RFC 6265 §5.1.4 path matching.
assert_eq Selenium::cookie_path_matches("/docs", "/docs")->{matches}, 1,        "cookie_path_matches: identical paths match"
assert_eq Selenium::cookie_path_matches("/docs/", "/docs/guide")->{matches}, 1, "cookie_path_matches: prefix ending in / matches"
assert_eq Selenium::cookie_path_matches("/docs", "/docs/guide")->{matches}, 1,  "cookie_path_matches: prefix at a / boundary matches"
assert_eq Selenium::cookie_path_matches("/docs", "/docsxyz")->{matches}, 0,     "cookie_path_matches: prefix not at a / boundary does not match"
assert_eq Selenium::cookie_path_matches("/Docs", "/docs/guide")->{matches}, 0,  "cookie_path_matches: paths are case-sensitive"
assert_dies fn { Selenium::cookie_path_matches("/x") }, "cookie_path_matches: needs a request path"

# css_escape: CSSOM serialize-an-identifier (browser CSS.escape).
assert_eq Selenium::css_escape("foo"),     "foo",       "css_escape: plain identifier unchanged"
assert_eq Selenium::css_escape("0foo"),    "\\30 foo",  "css_escape: leading digit escaped as code point"
assert_eq Selenium::css_escape("foo bar"), "foo\\ bar", "css_escape: space backslash-escaped"
assert_eq Selenium::css_escape("a#b.c"),   "a\\#b\\.c", "css_escape: punctuation escaped"
assert_eq "#" . Selenium::css_escape("user 42"), "#user\\ 42", "css_escape: builds a safe id selector"

# css_unescape: inverse of css_escape (CSS Syntax §4.3.7).
assert_eq Selenium::css_unescape("\\30 foo"),  "0foo",    "css_unescape: hex escape + trailing whitespace consumed"
assert_eq Selenium::css_unescape("foo\\ bar"), "foo bar", "css_unescape: backslash + non-hex char drops the backslash"
assert_eq Selenium::css_unescape("a\\#b\\.c"), "a#b.c",   "css_unescape: punctuation un-escaped"
assert_eq Selenium::css_unescape(Selenium::css_escape("user 42")), "user 42", "css_unescape: round-trips css_escape"
assert_eq Selenium::css_unescape(Selenium::css_escape("café")),    "café",    "css_unescape: round-trips non-ASCII"

# css_escape_string: escape + double-quote a CSS attribute-selector value.
assert_eq Selenium::css_escape_string("main"),  "\"main\"",        "css_escape_string: plain value wrapped in quotes"
assert_eq Selenium::css_escape_string("a\"b"),  "\"a\\\"b\"",      "css_escape_string: double-quote escaped"
assert_eq Selenium::css_escape_string("a\\b"),  "\"a\\\\b\"",      "css_escape_string: backslash escaped"
assert_eq "[data-id=" . Selenium::css_escape_string("x y") . "]", "[data-id=\"x y\"]", "css_escape_string: builds a safe attribute selector"

# build_css_selector: compose a selector from structured parts.
assert_eq Selenium::build_css_selector(tag => "input", id => "email", classes => ["form-control"], attributes => { type => "email" }), "input#email.form-control[type=\"email\"]", "build_css_selector: tag+id+class+attr"
assert_eq Selenium::build_css_selector(classes => ["a", "b"]), ".a.b", "build_css_selector: classes only"
assert_eq Selenium::build_css_selector(tag => "p", class => "lead"), "p.lead", "build_css_selector: single class string"
assert_eq Selenium::build_css_selector(id => "user 42"), "#user\\ 42", "build_css_selector: id is CSS-escaped"
assert_dies fn { Selenium::build_css_selector() }, "build_css_selector: needs at least one part"

# build_xpath: the XPath counterpart of build_css_selector.
assert_eq Selenium::build_xpath(tag => "button", text => "Log in"), "//button[text()='Log in']", "build_xpath: tag + exact text"
assert_eq Selenium::build_xpath(id => "main"), "//*[\@id='main']", "build_xpath: default * tag with an id predicate"
assert_eq Selenium::build_xpath(class => "active"), "//*[contains(concat(' ', normalize-space(\@class), ' '), ' active ')]", "build_xpath: single-class contains idiom"
assert_eq Selenium::build_xpath(tag => "a", contains_text => "more"), "//a[contains(text(), 'more')]", "build_xpath: substring text"
assert_eq Selenium::build_xpath(text => "it's"), "//*[text()=\"it's\"]", "build_xpath: value with a quote is XPath-quoted"
assert_dies fn { Selenium::build_xpath() }, "build_xpath: needs at least one part"

# xpath_literal: quote an arbitrary string as an XPath 1.0 string literal.
assert_eq Selenium::xpath_literal("Log in"),  q{'Log in'},          "xpath_literal: no quotes → single-quoted"
assert_eq Selenium::xpath_literal(q{it's}),   q{"it's"},            "xpath_literal: has ' → double-quoted"
assert_eq Selenium::xpath_literal(q{say "hi"}), q{'say "hi"'},      "xpath_literal: has \" → single-quoted"
assert_eq Selenium::xpath_literal(q{it's "x"}), q{concat('it', "'", 's "x"')}, "xpath_literal: both quotes → concat()"
assert_eq Selenium::xpath_literal(q{'}),      q{"'"},               "xpath_literal: lone ' uses double quotes"
# Builds a real text locator.
assert_eq "//button[text()=" . Selenium::xpath_literal(q{it's "go"}) . "]", q{//button[text()=concat('it', "'", 's "go"')]}, "xpath_literal: composes a text() locator"

test_run
