## t/test_selenium.stk — assertion tests for the stryke `Selenium` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Exercises the FFI surface without needing a WebDriver server:
## `supported_browsers`, `locator_strategies`, and `sessions` (empty when
## no browsers are open) are all pure dispatch into static state inside
## the cdylib — no chromedriver / geckodriver / safaridriver required, so
## they run unattended in CI.
##
## Live browser ops (open / goto / find / click / screenshot) need a
## running WebDriver server + a real browser, so they're not asserted
## here — they're exercised by `examples/selenium_*.stk` against a
## locally-launched chromedriver.

use Selenium

# ── Selenium::supported_browsers FFI roundtrip ──────────────────────
# Proves the FFI call path end-to-end: stryke → selenium__supported_browsers
# → JSON → stryke. No WebDriver server contacted.
val @browsers = Selenium::supported_browsers()
assert_ge scalar(@browsers), 4, "supported_browsers returns >= 4 names"

val %seen = map { $_ => 1 } @browsers
assert_ok $seen{chrome},  "browsers contain 'chrome'"
assert_ok $seen{firefox}, "browsers contain 'firefox'"
assert_ok $seen{safari},  "browsers contain 'safari'"
assert_ok $seen{edge},    "browsers contain 'edge'"

# ── Selenium::locator_strategies FFI roundtrip ──────────────────────
val @strats = Selenium::locator_strategies()
assert_ge scalar(@strats), 8, "locator_strategies returns >= 8 names"

val %sseen = map { $_ => 1 } @strats
assert_ok $sseen{css},               "strategies contain 'css'"
assert_ok $sseen{id},                "strategies contain 'id'"
assert_ok $sseen{xpath},             "strategies contain 'xpath'"
assert_ok $sseen{name},              "strategies contain 'name'"
assert_ok $sseen{tag},               "strategies contain 'tag'"
assert_ok $sseen{class},             "strategies contain 'class'"
assert_ok $sseen{link_text},         "strategies contain 'link_text'"
assert_ok $sseen{partial_link_text}, "strategies contain 'partial_link_text'"

# ── Selenium::sessions is empty when no browser open ────────────────
# The cdylib was just dlopened by this test; no `Selenium::open` has
# run, so the registry must be empty.
val @sessions = Selenium::sessions()
assert_eq scalar(@sessions), 0, "no sessions open before Selenium::open"

# active() returns undef when no session is active.
val $current = Selenium::active()
assert_ok !defined($current), "active() is undef when no session is open"

# ── quit_all is a no-op safe call when no sessions are open ─────────
val $closed = Selenium::quit_all()
assert_eq $closed, 0, "quit_all closes 0 sessions when none are open"

# ── pure helpers (no browser — always run) ───────────────────────────
val $css = Selenium::parse_locator("css=.btn.primary")
assert_eq $css->{strategy}, "css",         "parse_locator: css strategy"
assert_eq $css->{value},    ".btn.primary", "parse_locator: css value"
assert_eq Selenium::parse_locator("class_name=active")->{strategy}, "class", "parse_locator: alias canonicalized"
# embedded = in an xpath must survive
val $xp = Selenium::parse_locator("xpath=//input[\@type='text']")
assert_eq $xp->{value}, "//input[\@type='text']", "parse_locator: keeps embedded ="

# build_locator: inverse of parse_locator, strategy canonicalized.
assert_eq Selenium::build_locator("css", ".btn.primary")->{locator}, "css=.btn.primary", "build_locator: css"
assert_eq Selenium::build_locator("class_name", "active")->{locator}, "class=active", "build_locator: alias canonicalized"
assert_eq Selenium::build_locator("xpath", "//input[\@type='text']")->{locator}, "xpath=//input[\@type='text']", "build_locator: xpath with = round-trips"
assert_dies fn { Selenium::build_locator("bogus", "x") }, "build_locator: rejects unknown strategy"

val $vs = Selenium::valid_locator_strategy("TAG_NAME")
assert_ok $vs->{valid},                "valid_locator_strategy: alias is valid"
assert_eq $vs->{canonical}, "tag",     "valid_locator_strategy: canonical form"
assert_eq Selenium::valid_locator_strategy("nope")->{valid}, 0, "valid_locator_strategy: rejects unknown"

val $ck = Selenium::parse_cookie("session=abc123; Domain=.example.com; Path=/; Secure; HttpOnly")
assert_eq $ck->{name},   "session",       "parse_cookie: name"
assert_eq $ck->{value},  "abc123",        "parse_cookie: value"
assert_eq $ck->{domain}, ".example.com",  "parse_cookie: domain"
assert_eq $ck->{secure}, 1,               "parse_cookie: secure flag"
assert_eq $ck->{http_only}, 1,            "parse_cookie: http_only flag"

# build_cookie: inverse of parse_cookie (truthy flags become bare attributes).
assert_eq Selenium::build_cookie(name => "session", value => "abc123", domain => ".example.com", path => "/", same_site => "Lax", secure => 1, http_only => 1), "session=abc123; Domain=.example.com; Path=/; SameSite=Lax; Secure; HttpOnly", "build_cookie: full Set-Cookie string"
assert_eq Selenium::build_cookie(name => "k", value => "v"), "k=v", "build_cookie: minimal cookie, no flags"
assert_eq Selenium::parse_cookie(Selenium::build_cookie(name => "s", value => "x", secure => 1))->{secure}, 1, "build_cookie → parse_cookie round-trips the Secure flag"

test_run
