## Accept the current JS alert / confirm / prompt (clicks OK).
fn Selenium::accept_alert ($sid = undef) {
    var %args
    Selenium::_decode("accept_alert",
        selenium__accept_alert(to_json(Selenium::_with_session(%args, $sid))))
    1
}

## Dismiss the current JS alert / confirm / prompt (clicks Cancel).
fn Selenium::dismiss_alert ($sid = undef) {
    var %args
    Selenium::_decode("dismiss_alert",
        selenium__dismiss_alert(to_json(Selenium::_with_session(%args, $sid))))
    1
}

## Return the text of the current JS alert.
fn Selenium::alert_text ($sid = undef) {
    var %args
    val $o = Selenium::_decode("alert_text",
        selenium__alert_text(to_json(Selenium::_with_session(%args, $sid))))
    $o->{text}
}

## Type $text into the current JS prompt.
fn Selenium::send_alert_text ($text, $sid = undef) {
    var %args = (text => $text)
    Selenium::_decode("send_alert_text",
        selenium__send_alert_text(to_json(Selenium::_with_session(%args, $sid))))
    1
}

# ── window state ─────────────────────────────────────────────────────

## Maximize the current window.
fn Selenium::maximize ($sid = undef) {
    var %args
    Selenium::_decode("maximize",
        selenium__maximize(to_json(Selenium::_with_session(%args, $sid))))
    1
}

## Minimize the current window.
fn Selenium::minimize ($sid = undef) {
    var %args
    Selenium::_decode("minimize",
        selenium__minimize(to_json(Selenium::_with_session(%args, $sid))))
    1
}

## Put the current window into fullscreen mode.
fn Selenium::fullscreen ($sid = undef) {
    var %args
    Selenium::_decode("fullscreen",
        selenium__fullscreen(to_json(Selenium::_with_session(%args, $sid))))
    1
}

# ── element scroll + print ───────────────────────────────────────────

## Scroll element $eid into the viewport.
fn Selenium::scroll_to_element ($eid) {
    var %args = (element => $eid)
    Selenium::_decode("scroll_to_element", selenium__scroll_to_element(to_json(\%args)))
    1
}

## Print the current page to a PDF at $path (Chrome/Firefox headless). Returns
## the path.
fn Selenium::print_page ($path, $sid = undef) {
    var %args = (output => $path)
    Selenium::_decode("print_page",
        selenium__print_page(to_json(Selenium::_with_session(%args, $sid))))->{path}
}

# ── pure helpers (no browser) ─────────────────────────────────────────

## Parse a "strategy=value" locator ("css=.btn", "xpath=//a", "id=main") into a
## hashref { strategy, value } with the strategy canonicalized for find(). A
## bare value with no "=" defaults to css.
fn Selenium::parse_locator ($locator) {
    Selenium::_decode("parse_locator", selenium__parse_locator(to_json({ locator => $locator })))
}

## Build a "strategy=value" locator from parts — inverse of parse_locator. The
## strategy is canonicalized (css_selector → css) and rejected if unknown.
## Returns a hashref { locator, strategy }.
fn Selenium::build_locator ($strategy, $value) {
    Selenium::_decode("build_locator",
        selenium__build_locator(to_json({ strategy => $strategy, value => $value })))
}

## Validate a locator strategy name → { strategy, valid, canonical }.
fn Selenium::valid_locator_strategy ($strategy) {
    Selenium::_decode("valid_locator_strategy",
        selenium__valid_locator_strategy(to_json({ strategy => $strategy })))
}

## Translate a locator to the W3C WebDriver { using, value } pair sent on the
## wire. Native strategies (css/xpath/tag/link/partial) pass through; id, name,
## and class collapse to a "css selector" ([id="…"], [name="…"], [class~="…"]).
## Pass $strategy + $value, or a single $strategy="value" locator string.
fn Selenium::locator_to_w3c ($strategy, $value = undef) {
    val $req = defined($value) ? { strategy => $strategy, value => $value } : { locator => $strategy }
    Selenium::_decode("locator_to_w3c", selenium__locator_to_w3c(to_json($req)))
}

## Translate a W3C WebDriver { using, value } pair back to a canonical
## strategy=value locator — the inverse of locator_to_w3c for the five
## protocol strategies (css selector, xpath, tag name, link text, partial
## link text). Returns { strategy, value, locator }.
fn Selenium::w3c_to_locator ($using, $value) {
    Selenium::_decode("w3c_to_locator", selenium__w3c_to_locator(to_json({ using => $using, value => $value })))
}

## Resolve a WebDriver special key name to its Private-Use-Area code point ("Enter"
## → U+E007), as send_keys uses to press control/navigation keys. Names are
## case-insensitive and ignore _/-/spaces; F1–F12 and aliases (esc, ctrl, del,
## arrowup) work. Returns a hashref { key, code_point, codepoint, char }.
fn Selenium::key_code ($key) {
    Selenium::_decode("key_code", selenium__key_code(to_json({ key => $key })))
}

## Resolve a WebDriver PUA code point back to its canonical key name — inverse
## of key_code. %opts: codepoint (integer) or char (the PUA character). Returns
## a hashref { key, code_point, codepoint, char }; return/enter stay distinct.
fn Selenium::key_name (%opts) {
    Selenium::_decode("key_name", selenium__key_name(to_json(\%opts)))
}

## Parse a Set-Cookie-style string into the structured cookie add_cookie wants:
## { name, value, domain, path, secure, http_only, same_site, expires }.
fn Selenium::parse_cookie ($cookie) {
    Selenium::_decode("parse_cookie", selenium__parse_cookie(to_json({ cookie => $cookie })))
}

## Build a Set-Cookie-style string from structured fields — inverse of
## parse_cookie. %opts: name (required), value, domain, path, same_site,
## expires, secure, http_only (the last two are bare flags when truthy).
fn Selenium::build_cookie (%opts) {
    Selenium::_decode("build_cookie", selenium__build_cookie(to_json(\%opts)))->{cookie}
}

## Escape a string as a CSS identifier (the CSSOM "serialize an identifier"
## algorithm, a.k.a. browser CSS.escape) so an arbitrary id/class value can be
## embedded in a CSS-strategy locator: "#" . Selenium::css_escape($id). Returns
## the escaped string.
fn Selenium::css_escape ($value) {
    Selenium::_decode("css_escape", selenium__css_escape(to_json({ value => $value })))->{escaped}
}

## Build a CSS selector from %parts: tag, id (# + CSS-escaped), classes (arrayref
## or a single class string, each . + CSS-escaped), and attributes/attrs (hashref
## { name => value }, each [name="value"] with the value escaped). Concatenated
## tag→id→classes→attributes. Returns the selector string.
fn Selenium::build_css_selector (%parts) {
    Selenium::_decode("build_css_selector", selenium__build_css_selector(to_json(\%parts)))->{selector}
}
